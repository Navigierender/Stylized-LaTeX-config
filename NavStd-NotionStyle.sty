%NavStd-NotionStyle by Navigierender
%https://github.com/Navigierender/Stylized-LaTeX-config

\ProvidesPackage{NavStd-NotionStyle}[2026/04/13]

\RequirePackage{tabu}
\RequirePackage{geometry}
\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\RequirePackage{titlesec}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\tcbuselibrary{skins,listings}
\RequirePackage[sfdefault,light]{FiraSans}
\RequirePackage[T1]{fontenc}
\RequirePackage{FiraMono}

\renewcommand*\oldstylenums[1]{{\firaoldstyle #1}}

\geometry{
  a4paper, left=20mm, top=20mm
}

\tabulinesep = 1.5mm

\definecolor{black}{HTML}{212529}
\definecolor{gray}{HTML}{6C757D}
\definecolor{lightgray}{HTML}{ADB5BD}
\definecolor{tintedwhite}{HTML}{F8F9FA}

\definecolor{codeDark}{HTML}{252422}
\definecolor{codeSemidark}{HTML}{403d39}
\definecolor{codeSemilight}{HTML}{CCC5B9}
\definecolor{codeLight}{HTML}{FFFCF2}
\definecolor{codeAccent}{HTML}{EB5E28}
\definecolor{codeSemiaccent}{HTML}{d98e71}

\newcommand*{\Svspace}{\vspace{6pt}}
\newcommand*{\Mvspace}{\vspace{2ex}}
\newcommand*{\Lvspace}{\vspace{6ex}}

\newcommand{\thinrule}{
\par\Mvspace
\color{lightgray} \hrule height 0.2pt \color{black}
\Mvspace\par
}

\newcommand{\used}[1]{
  \tcbox[
    enhanced,
    frame hidden,
    boxrule=0pt,
    colback=tintedwhite,
    arc=2mm,
    left=1pt,
    right=1pt,
    top=1pt,
    bottom=1pt,
    nobeforeafter,
    before upper={\small\itshape},
    after upper={}
  ]{\color{gray}{#1}}
}

\newenvironment{Nquote}{
  \begin{tcolorbox}[
    enhanced,
    frame hidden,
    borderline west={1.6pt}{0pt}{lightgray},
    boxsep=1pt,
    top=0pt,
    bottom=0pt,
    left skip=0pt,
    boxrule=0pt,
    colback=white,
    parbox=false,
    right skip=0pt,
    right=0pt,
    parskip=\Mvspace
  ]
}{
  \end{tcolorbox}
}

\newtcolorbox{Nbox}{
  enhanced,
  colback=white,
  colframe=tintedwhite,
  boxrule=1.6pt,
  arc=2ex,
  boxsep=1mm,
  halign=center,
  valign=center,
  after skip=2ex,
  before skip=2ex
}

\tcbuselibrary{listings}

\newtcblisting{Ncode}[1]{
  listing only,
  listing options={
    xleftmargin=18pt,
    language=#1,
    backgroundcolor=\color{white},
    commentstyle=\color{codeSemilight},
    keywordstyle=\color{codeAccent},
    stringstyle=\color{codeSemiaccent},
    identifierstyle=\color{codeSemidark},
    numberstyle=\color{lightgray},
    basicstyle=\fontfamily{fvm}\selectfont\small\color{codeDark},
    breaklines=true,
    captionpos=b,
    numbers=left,
    numbersep=5pt,
    showspaces=false,
    showstringspaces=false
  },
  enhanced,
  colback=white,
  colframe=tintedwhite,
  boxrule=1.6pt,
  arc=2ex,
  left=5pt,
  right=5pt,
  top=0pt,
  bottom=0pt
}

\titleformat{\subsection}
  {\normalfont\large\bfseries\color{gray}}
  {\thesubsection}
  {1em}
  {}

\expandafter\def\expandafter\normalsize\expandafter{%
  \normalsize%
  \setlength\abovedisplayskip{0pt}%
  \setlength\belowdisplayskip{8pt}%
  \setlength\abovedisplayshortskip{-8pt}%
  \setlength\belowdisplayshortskip{-8pt}%
}

\titlespacing*{\section}{0pt}{2ex}{3pt}

\AtBeginDocument{
  \raggedright
  \mathcode`|=\string"8000
  \begingroup\lccode`\~=`\|
  \lowercase{\endgroup\def~}{\mathrel{\vert}}
}
